# Maintainer: ClaudeView Contributors
pkgname=claudeview
pkgver=%%PKGVER%%
pkgrel=1
pkgdesc="Dashboard for browsing and inspecting Claude Code agent sessions"
arch=('x86_64')
url="https://github.com/much-sebastiaocerqueira/claudeview"
license=('MIT')
depends=('c-ares' 'gcc-libs' 'glibc' 'gtk3' 'libcups' 'libdrm' 'libnotify' 'libxcrypt-compat' 'libxss' 'mesa' 'nss' 'alsa-lib')
source=("${pkgname}-${pkgver}.pacman::https://github.com/much-sebastiaocerqueira/claudeview/releases/download/v${pkgver}/claudeview-${pkgver}.pacman")
sha256sums=('%%SHA256%%')

package() {
    cd "${srcdir}"
    tar -xf "${pkgname}-${pkgver}.pacman" -C "${pkgdir}/" \
        --exclude='.MTREE' --exclude='.PKGINFO' --exclude='.INSTALL'

    # chrome-sandbox requires suid for Chromium sandboxing
    chmod 4755 "${pkgdir}/opt/ClaudeView/chrome-sandbox"
}
