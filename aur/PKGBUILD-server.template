# Maintainer: ClaudeView Contributors
pkgname=claudeview-server
pkgver=%%PKGVER%%
pkgrel=1
pkgdesc="Headless web server for ClaudeView — Claude Code session dashboard"
arch=('x86_64' 'aarch64')
url="https://github.com/much-sebastiaocerqueira/claudeview"
license=('MIT')
depends=('bun')
makedepends=('git' 'python' 'nodejs')
conflicts=()
source=("git+${url}.git#tag=v${pkgver}")
sha256sums=('SKIP')

build() {
  cd claudeview
  bun install --frozen-lockfile
  bun run build
}

package() {
  cd claudeview

  # Install application files
  install -dm755 "${pkgdir}/opt/${pkgname}"

  # Copy built frontend
  cp -r dist "${pkgdir}/opt/${pkgname}/"

  # Copy server + electron/server.ts (reused by standalone entry point)
  cp -r server "${pkgdir}/opt/${pkgname}/"
  cp -r electron "${pkgdir}/opt/${pkgname}/"
  cp -r src "${pkgdir}/opt/${pkgname}/"

  # Copy claudeview-memory CLI source (used by /api/claudeview-search route)
  install -dm755 "${pkgdir}/opt/${pkgname}/packages/claudeview-memory"
  cp -r packages/claudeview-memory/src "${pkgdir}/opt/${pkgname}/packages/claudeview-memory/"
  cp packages/claudeview-memory/package.json "${pkgdir}/opt/${pkgname}/packages/claudeview-memory/"
  cp package.json "${pkgdir}/opt/${pkgname}/"
  cp tsconfig.json "${pkgdir}/opt/${pkgname}/" 2>/dev/null || true
  cp -r node_modules "${pkgdir}/opt/${pkgname}/"

  # Install systemd user unit
  install -Dm644 aur/claudeview-server.service \
    "${pkgdir}/usr/lib/systemd/user/${pkgname}.service"

  # Install license (if present)
  if [ -f LICENSE ]; then
    install -Dm644 LICENSE "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
  fi
}
