{
  "name": "claudeview",
  "private": true,
  "version": "0.1.0",
  "description": "Session viewer for Claude Code with side-by-side diffs and session timeline",
  "license": "MIT",
  "author": {
    "name": "Gentrit Biba",
    "email": "gentritbiba@gmail.com"
  },
  "type": "module",
  "main": "out/main/main.js",
  "scripts": {
    "dev": "rm -rf node_modules/.vite-temp && vite --host",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "lint": "eslint .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "electron:dev": "electron-vite dev",
    "electron:build": "electron-vite build",
    "electron:preview": "electron-vite build && electron .",
    "electron:package": "start=$(date +%s) && electron-vite build && electron-builder --publish never && echo \"\\n✅ electron:package completed in $(($(date +%s) - start))s\"",
    "postinstall": "electron-builder install-app-deps",
    "serve": "bun run build && bun server/standalone.ts",
    "serve:start": "bun server/standalone.ts",
    "sync-cogpit-memory": "bun scripts/sync-cogpit-memory.ts"
  },
  "dependencies": {
    "@base-ui/react": "^1.2.0",
    "@fontsource-variable/geist": "^5.2.8",
    "@git-diff-view/file": "^0.1.3",
    "@git-diff-view/react": "^0.1.3",
    "@git-diff-view/shiki": "^0.1.3",
    "@tanstack/react-virtual": "^3.13.18",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-web-links": "^0.12.0",
    "@xterm/xterm": "^6.0.0",
    "better-sqlite3": "^12.6.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "electron-updater": "^6.8.3",
    "express": "^5.2.1",
    "lucide-react": "^0.577.0",
    "node-pty": "^1.1.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-markdown": "^9.0.3",
    "react-resizable-panels": "^4.7.1",
    "remark-gfm": "^4.0.1",
    "shadcn": "^4.0.0",
    "shiki": "^3.22.0",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "whisper-web-transcriber": "^0.2.5",
    "ws": "^8.19.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@tailwindcss/vite": "^4.0.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/express": "^5.0.6",
    "@types/jsdom": "^27.0.0",
    "@types/node": "^25.2.3",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^4.3.4",
    "babel-plugin-react-compiler": "^1.0.0",
    "electron": "^40.4.1",
    "electron-builder": "^26.7.0",
    "electron-vite": "^5.0.0",
    "eslint": "^9.17.0",
    "eslint-plugin-react-hooks": "^5.0.0",
    "eslint-plugin-react-refresh": "^0.4.16",
    "globals": "^15.14.0",
    "happy-dom": "^20.6.2",
    "jsdom": "^28.1.0",
    "tailwindcss": "^4.0.0",
    "typescript": "~5.6.2",
    "typescript-eslint": "^8.18.2",
    "vite": "^6.0.5",
    "vitest": "^4.0.18"
  }
}
